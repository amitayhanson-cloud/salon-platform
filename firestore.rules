rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read/write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Websites: owner can read/write their documents; anyone authenticated can create (ownerUserId set to their uid)
    match /websites/{websiteId} {
      allow read, update, delete: if request.auth != null && resource.data.ownerUserId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerUserId == request.auth.uid;
    }

    // Sites: public read for public site + booking; only owner can write.
    match /sites/{siteId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || resource.data.ownerUserId == request.auth.uid);
    }

    // Workers: public read for booking flow; write only if user owns the site.
    match /sites/{siteId}/workers/{workerId} {
      allow read: if true;
      allow write: if request.auth != null
        && (get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUid == request.auth.uid
            || get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUserId == request.auth.uid);
    }

    // Booking settings: public read for business hours/availability; write only owner.
    match /sites/{siteId}/settings/booking {
      allow read: if true;
      allow write: if request.auth != null
        && (get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUid == request.auth.uid
            || get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUserId == request.auth.uid);
    }

    // Bookings: public read (slot availability) and create (submit booking); update/delete only site owner.
    match /sites/{siteId}/bookings/{bookingId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null
        && (get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUid == request.auth.uid
            || get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUserId == request.auth.uid);
    }

    // Pricing items/categories: public read for booking flow; write only owner.
    match /sites/{siteId}/pricingItems/{itemId} {
      allow read: if true;
      allow write: if request.auth != null
        && (get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUid == request.auth.uid
            || get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUserId == request.auth.uid);
    }
    match /sites/{siteId}/pricingCategories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null
        && (get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUid == request.auth.uid
            || get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUserId == request.auth.uid);
    }

    // Clients: public read/update (getOrCreateClient, personal pricing when submitting booking); delete only site owner.
    match /sites/{siteId}/clients/{clientId} {
      allow read, create, update: if true;
      allow delete: if request.auth != null
        && (get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUid == request.auth.uid
            || get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUserId == request.auth.uid);
    }

    // Archived bookings per client+serviceType (one doc per serviceTypeId for history). Same auth as clients.
    match /sites/{siteId}/clients/{clientId}/archivedServiceTypes/{serviceTypeId} {
      allow read, write: if request.auth != null
        && (get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUid == request.auth.uid
            || get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUserId == request.auth.uid);
    }

    // Multi-booking combos (packages): public read for booking flow; write only site owner.
    match /sites/{siteId}/multiBookingCombos/{comboId} {
      allow read: if true;
      allow write: if request.auth != null
        && (get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUid == request.auth.uid
            || get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUserId == request.auth.uid);
    }

    // Other subcollections under sites (tasks, etc.): only if user owns the site
    match /sites/{siteId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null
        && (get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUid == request.auth.uid
            || get(/databases/$(database)/documents/sites/$(siteId)).data.ownerUserId == request.auth.uid);
    }

    // Platform landing page content (CMS): public read; write by authenticated (admin gated in app)
    match /platform/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Templates catalog used by onboarding builder (read-only from client).
    match /templates/{templateId} {
      allow read: if true;
      allow write: if false;
    }

    // Pending builder onboarding (server / Admin SDK only — never client).
    match /onboardingPending/{userId} {
      allow read, write: if false;
    }

    // Tenants (subdomain slug -> siteId): public read for routing; create only when ownerUid == auth; update/delete only owner; no changing ownerUid/siteId on update.
    match /tenants/{slug} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && (request.resource.data.ownerUid == resource.data.ownerUid)
        && (request.resource.data.siteId == resource.data.siteId);
    }
  }
}
